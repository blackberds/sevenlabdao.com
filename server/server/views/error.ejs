<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - BITNEST Admin</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 40px; }
        .error { color: #d32f2f; padding: 20px; background-color: #ffebee; border: 1px solid #d32f2f; }
    </style>
</head>
<body>
    <h1>Error</h1>
    <div class="error">
        <p><%= message %></p>
    </div>
    <p><a href="/admin?secret=<%= query.secret %>">Back to Dashboard</a></p>
</body>
</html>