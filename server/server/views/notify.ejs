<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Send Notification - BITNEST Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #667eea;
            --secondary: #764ba2;
            --success: #48bb78;
            --warning: #ed8936;
            --danger: #f56565;
            --info: #4299e1;
            --light: #f7fafc;
            --dark: #2d3748;
            --gray: #a0aec0;
            --border: #e2e8f0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
/* Добавьте в CSS */
#confirmCodeInput:focus {
    outline: none;
    border-color: var(--danger);
    box-shadow: 0 0 0 3px rgba(245, 101, 101, 0.1);
}

#confirmCodeInput.error {
    border-color: var(--danger);
    box-shadow: 0 0 0 3px rgba(245, 101, 101, 0.1);
}

.confirm-code-display {
    font-family: 'Courier New', monospace;
    font-size: 1.2rem;
    letter-spacing: 3px;
    padding: 5px 10px;
    background: var(--light);
    border-radius: 5px;
    margin: 10px 0;
    color: var(--danger);
    font-weight: bold;
}
        body {
            font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            color: var(--dark);
            line-height: 1.6;
            padding: 20px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.1);
            padding: 30px;
            border: 1px solid var(--border);
        }

        .back-link {
            margin-bottom: 25px;
        }

        .back-link a {
            display: inline-flex;
            align-items: center;
            padding: 12px 20px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 500;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
        }

        .back-link a:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        h1 {
            font-size: 2.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        .notification-form {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 5px 25px rgba(0, 0, 0, 0.08);
            border: 1px solid var(--border);
        }

        .form-group {
            margin-bottom: 25px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--dark);
        }

        input, textarea, select {
            width: 100%;
            padding: 15px;
            border: 2px solid var(--border);
            border-radius: 10px;
            font-size: 1rem;
            transition: all 0.3s ease;
            background: var(--light);
        }

        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        textarea {
            min-height: 150px;
            resize: vertical;
        }

        .btn {
            padding: 15px 30px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn i {
            margin-right: 8px;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            font-size: 1.1rem;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }

        .btn-warning {
            background: linear-gradient(135deg, var(--warning), var(--danger));
            color: white;
            font-size: 1.1rem;
        }

        .btn-warning:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(237, 137, 54, 0.4);
        }

        .btn-primary:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-item {
            background: white;
            padding: 20px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            border: 1px solid var(--border);
        }

        .stat-number {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 5px;
        }

        .stat-label {
            color: var(--gray);
            font-size: 0.9rem;
            font-weight: 500;
        }

        /* Quick actions */
        .quick-actions {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .quick-action-card {
            background: white;
            padding: 25px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 5px 25px rgba(0, 0, 0, 0.08);
            border: 1px solid var(--border);
            transition: all 0.3s ease;
        }

        .quick-action-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
        }

        .quick-action-icon {
            font-size: 2.5rem;
            margin-bottom: 15px;
        }

        .quick-action-title {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 10px;
            color: var(--dark);
        }

        .quick-action-desc {
            color: var(--gray);
            margin-bottom: 20px;
            line-height: 1.5;
        }

        .user-count {
            background: var(--light);
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
            color: var(--primary);
            font-weight: 600;
            margin-bottom: 15px;
            display: inline-block;
        }

        /* Loading animation */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .loading-overlay.active {
            opacity: 1;
            visibility: visible;
        }
    /* Новые стили для блокированных пользователей */
        .blocked-users-section {
            margin-top: 30px;
            padding: 20px;
            background: rgba(245, 101, 101, 0.1);
            border-radius: 10px;
            border: 1px solid var(--danger);
        }

        .blocked-users-section h3 {
            color: var(--danger);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
/* В разделе стилей для кнопок добавьте */
.btn-danger-lg {
    background: linear-gradient(135deg, var(--danger), #c53030);
    color: white;
    font-size: 1rem;
    padding: 12px 25px;
}

.btn-danger-lg:hover {
    background: linear-gradient(135deg, #e53e3e, #c53030);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(245, 101, 101, 0.4);
}
        .blocked-users-list {
            max-height: 300px;
            overflow-y: auto;
            background: white;
            border-radius: 8px;
            padding: 10px;
        }

        .blocked-user-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 15px;
            border-bottom: 1px solid var(--border);
            transition: background-color 0.2s ease;
        }

        .blocked-user-item:hover {
            background-color: var(--light);
        }

        .blocked-user-item:last-child {
            border-bottom: none;
        }

        .blocked-user-info {
            display: flex;
            flex-direction: column;
            gap: 5px;
            flex: 1;
        }

        .blocked-user-name {
            font-weight: 600;
            color: var(--dark);
        }

        .blocked-user-id {
            font-size: 0.8rem;
            color: var(--gray);
        }

        .blocked-user-date {
            font-size: 0.8rem;
            color: var(--gray);
        }

        .blocked-user-status {
            background: var(--danger);
            color: white;
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 0.7rem;
            font-weight: 600;
            margin-right: 10px;
        }

        .blocked-user-actions {
            display: flex;
            gap: 8px;
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 0.8rem;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .btn-danger {
            background: var(--danger);
            color: white;
        }

        .btn-danger:hover {
            background: #e53e3e;
            transform: translateY(-1px);
        }

        .btn-success {
            background: var(--success);
            color: white;
        }

        .btn-success:hover {
            background: #38a169;
            transform: translateY(-1px);
        }

        .blocked-stats {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
            flex-wrap: wrap;
        }

        .blocked-stat {
            background: white;
            padding: 10px 15px;
            border-radius: 8px;
            border: 1px solid var(--danger);
        }

        .blocked-stat-number {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--danger);
        }

        .blocked-stat-label {
            font-size: 0.8rem;
            color: var(--dark);
        }

        .no-blocked-users {
            text-align: center;
            padding: 20px;
            color: var(--gray);
            font-style: italic;
        }

        /* Стили для результатов с блокированными пользователями */
        .blocked-results {
            margin-top: 20px;
            padding: 15px;
            background: rgba(245, 101, 101, 0.05);
            border-radius: 8px;
            border: 1px solid var(--danger);
        }

        .blocked-results h4 {
            color: var(--danger);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .blocked-results-list {
            max-height: 200px;
            overflow-y: auto;
        }

        .blocked-result-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 12px;
            background: white;
            border-radius: 6px;
            margin-bottom: 5px;
            border-left: 3px solid var(--danger);
        } 
        .spinner {
            width: 70px;
            height: 70px;
            border: 5px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
            margin-bottom: 20px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .loading-text {
            color: white;
            font-size: 1.2rem;
            font-weight: 500;
        }

        .progress-bar {
            width: 300px;
            height: 10px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 5px;
            margin-top: 15px;
            overflow: hidden;
        }

        .progress {
            height: 100%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            width: 0%;
            transition: width 0.3s ease;
        }

        /* Results modal */
        .results-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1001;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .results-modal.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background: white;
            border-radius: 15px;
            padding: 30px;
            max-width: 500px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.2);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--border);
        }

        .modal-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--primary);
        }

        .close-modal {
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--gray);
            transition: color 0.3s ease;
        }

        .close-modal:hover {
            color: var(--danger);
        }

        .result-item {
            margin-bottom: 15px;
            padding: 15px;
            border-radius: 10px;
            background: var(--light);
        }

        .result-success {
            border-left: 4px solid var(--success);
        }

        .result-error {
            border-left: 4px solid var(--danger);
        }

        .result-warning {
            border-left: 4px solid var(--warning);
        }

        .blocked-users {
            margin-top: 20px;
            padding: 20px;
            background: rgba(245, 101, 101, 0.1);
            border-radius: 10px;
            border: 1px solid var(--danger);
        }

        .blocked-users h4 {
            color: var(--danger);
            margin-bottom: 10px;
        }

        .blocked-users-list {
            max-height: 200px;
            overflow-y: auto;
        }

        .blocked-user {
            padding: 8px 12px;
            background: white;
            border-radius: 5px;
            margin-bottom: 5px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-template {
            padding: 8px 16px;
            background: linear-gradient(135deg, var(--info), var(--primary));
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 0.8rem;
            cursor: pointer;
            margin-top: 10px;
            transition: all 0.3s ease;
        }

        .btn-template:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(66, 153, 225, 0.3);
        }

        @media (max-width: 768px) {
            .container {
                padding: 20px;
                margin: 10px;
            }
            
            h1 {
                font-size: 2rem;
            }
            
            .stats-grid,
            .quick-actions {
                grid-template-columns: 1fr;
            }
            
            .progress-bar {
                width: 250px;
            }
            
            .blocked-user-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }
            
            .blocked-user-actions {
                align-self: flex-end;
            }
        }
		/* Добавьте в ваш CSS */
.result-info {
    border-left: 4px solid var(--info);
    background: rgba(66, 153, 225, 0.1);
}

.stat-item.warning {
    background: linear-gradient(135deg, #fff9e6, #fff1cc);
    border: 1px solid var(--warning);
}

.stat-item.danger {
    background: linear-gradient(135deg, #ffe6e6, #ffcccc);
    border: 1px solid var(--danger);
}

/* Стили для модального окна подтверждения */
.confirmation-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1002;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
}

.confirmation-modal.active {
    opacity: 1;
    visibility: visible;
}

.confirmation-content {
    background: white;
    border-radius: 15px;
    padding: 30px;
    max-width: 400px;
    width: 90%;
    text-align: center;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.2);
}

.confirmation-icon {
    font-size: 3rem;
    margin-bottom: 20px;
}

.confirmation-icon.warning {
    color: var(--warning);
}

.confirmation-icon.danger {
    color: var(--danger);
}

.confirmation-icon.success {
    color: var(--success);
}

.confirmation-text {
    margin-bottom: 25px;
    line-height: 1.6;
}

.confirmation-buttons {
    display: flex;
    gap: 15px;
    justify-content: center;
}

.confirm-btn {
    padding: 12px 24px;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
}

.confirm-btn-danger {
    background: var(--danger);
    color: white;
}

.confirm-btn-danger:hover {
    background: #e53e3e;
    transform: translateY(-2px);
}

.confirm-btn-success {
    background: var(--success);
    color: white;
}

.confirm-btn-success:hover {
    background: #38a169;
    transform: translateY(-2px);
}

.confirm-btn-cancel {
    background: var(--gray);
    color: white;
}

.confirm-btn-cancel:hover {
    background: #718096;
    transform: translateY(-2px);
}
    </style>
</head>
<body>
    <div class="container">
        <div class="back-link">
            <a href="/admin?secret=<%= query.secret %>">
                <i class="fas fa-arrow-left"></i>Back to Dashboard
            </a>
        </div>

        <div class="header">
            <h1><i class="fas fa-bullhorn"></i>Send Notification</h1>
            <p>Send messages to all users or specific groups</p>
        </div>

        <div class="stats-grid">
    <div class="stat-item">
        <div class="stat-number" id="totalUsers"><%= typeof totalUsers !== 'undefined' ? totalUsers : '0' %></div>
        <div class="stat-label">Total Users</div>
    </div>
    <div class="stat-item">
        <div class="stat-number" id="activeUsers"><%= typeof activeUsers !== 'undefined' ? activeUsers : '0' %></div>
        <div class="stat-label">Active Users (7 days)</div>
    </div>
    <div class="stat-item">
        <div class="stat-number" id="blockedUsers"><%= typeof blockedUsers !== 'undefined' ? blockedUsers : '0' %></div>
        <div class="stat-label">Blocked Bot</div>
    </div>
    <div class="stat-item">
        <div class="stat-number" id="noInvestmentsUsers"><%= typeof noInvestmentsUsers !== 'undefined' ? noInvestmentsUsers : '0' %></div>
        <div class="stat-label">No Investments</div>
    </div>
    <div class="stat-item">
        <div class="stat-number" id="urgentSubscriptions"><%= typeof urgentSubscriptions !== 'undefined' ? urgentSubscriptions : '0' %></div>
        <div class="stat-label">Urgent (1-3 days)</div>
    </div>
    <div class="stat-item">
        <div class="stat-number" id="expiringSubscriptions"><%= typeof expiringSubscriptions !== 'undefined' ? expiringSubscriptions : '0' %></div>
        <div class="stat-label">Expiring Soon (7 days)</div>
    </div>
</div>

        <!-- Быстрые действия -->
        <div class="quick-actions">
            <div class="quick-action-card">
                <div class="quick-action-icon" style="color: var(--warning);">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="quick-action-title">Срочное напоминание</div>
                <div class="user-count">
                    <i class="fas fa-users"></i> 
                    <%= typeof urgentSubscriptions !== 'undefined' ? urgentSubscriptions : '0' %> пользователей
                </div>
                <div class="quick-action-desc">
                    Автоматическая рассылка пользователям с 1-3 днями до окончания подписки
                </div>
                <button type="button" class="btn btn-warning" id="urgentReminderBtn">
                    <i class="fas fa-bolt"></i>Отправить срочное напоминание
                </button>
            </div>

            <div class="quick-action-card">
                <div class="quick-action-icon" style="color: var(--info);">
                    <i class="fas fa-hourglass-half"></i>
                </div>
                <div class="quick-action-title">Напоминание за неделю</div>
                <div class="user-count">
                    <i class="fas fa-users"></i> 
                    <%= typeof expiringSubscriptions !== 'undefined' ? expiringSubscriptions : '0' %> пользователей
                </div>
                <div class="quick-action-desc">
                    Рассылка пользователям с 4-7 днями до окончания подписки
                </div>
                <button type="button" class="btn btn-primary" id="weekReminderBtn">
                    <i class="fas fa-envelope"></i>Отправить напоминание
                </button>
            </div><!-- НОВАЯ КАРТОЧКА ДЛЯ НОВЫХ ПОЛЬЗОВАТЕЛЕЙ -->
    <div class="quick-action-card">
        <div class="quick-action-icon" style="color: var(--success);">
            <i class="fas fa-gift"></i>
        </div>
        <div class="quick-action-title">Бонус для новых</div>
        <div class="user-count">
            <i class="fas fa-users"></i> 
            <%= typeof noInvestmentsUsers !== 'undefined' ? noInvestmentsUsers : '0' %> пользователей
        </div>
        <div class="quick-action-desc">
            Рассылка пользователям которые никогда не инвестировали (бонус $10,000)
        </div>
        <button type="button" class="btn" style="background: linear-gradient(135deg, var(--success), var(--info)); color: white;" id="bonusReminderBtn">
            <i class="fas fa-gift"></i>Отправить бонусное предложение
        </button>
    </div>
</div>

        <!-- Детальная статистика по подпискам -->
        <% if (typeof pendingSubscriptions !== 'undefined' || typeof timeExpiredSubscriptions !== 'undefined') { %>
        <div style="margin-top: 20px; padding: 15px; background: var(--light); border-radius: 10px;">
            <h4 style="color: var(--primary); margin-bottom: 10px;">
                <i class="fas fa-info-circle"></i> Детализация подписок:
            </h4>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px;">
                <div style="text-align: center;">
                    <div style="font-size: 1.2rem; font-weight: bold; color: var(--warning);">
                        <%= typeof urgentSubscriptions !== 'undefined' ? urgentSubscriptions : '0' %>
                    </div>
                    <div style="font-size: 0.8rem; color: var(--gray);">Urgent (1-3 дня)</div>
                </div>
                <div style="text-align: center;">
                    <div style="font-size: 1.2rem; font-weight: bold; color: var(--info);">
                        <%= typeof expiringSubscriptions !== 'undefined' ? (expiringSubscriptions - urgentSubscriptions) : '0' %>
                    </div>
                    <div style="font-size: 0.8rem; color: var(--gray);">Warning (4-7 дней)</div>
                </div>
                <div style="text-align: center;">
                    <div style="font-size: 1.2rem; font-weight: bold; color: var(--danger);">
                        <%= typeof expiredSubscriptions !== 'undefined' ? expiredSubscriptions : '0' %>
                    </div>
                    <div style="font-size: 0.8rem; color: var(--gray);">Expired (истекли)</div>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Ручная рассылка -->
        <div class="notification-form" style="margin-top: 30px;">
            <h3 style="color: var(--primary); margin-bottom: 20px; text-align: center;">
                <i class="fas fa-edit"></i> Ручная рассылка
            </h3>
            <form id="notificationForm" action="/admin/notify?secret=<%= query.secret %>" method="POST">
                <div class="form-group">
                    <label for="messageType"><i class="fas fa-tag"></i>Тип сообщения</label>
                    <select id="messageType" name="messageType" required>
                        <option value="announcement">📢 АНОНС</option>
                        <option value="update">🔄 ОБНОВЛЕНИЕ</option>
                        <option value="promotion">🎁 АКЦИЯ</option>
                        <option value="alert">⚠️ ВАЖНОЕ УВЕДОМЛЕНИЕ</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="recipients"><i class="fas fa-users"></i>Получатели</label>
                    <select id="recipients" name="recipients" required>
                        <option value="all">Все пользователи</option>
                        <option value="active">Только активные пользователи</option>
                        <option value="inactive">Неактивные пользователи</option>
                        <option value="premium">Премиум-пользователи</option>
                        <option value="no_investments">Пользователи без инвестиций</option>
                        <option value="with_investments">Пользователи с инвестициями</option>
                        <option value="expired_subscription">Подписка истекла</option>
                        <option value="expiring_subscription">Подписка истекает скоро (7 дней)</option>
                        <option value="urgent_subscription">СРОЧНО: 1-3 дня до конца</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="message"><i class="fas fa-comment"></i>Текст сообщения</label>
                    <textarea id="message" name="message" placeholder="Введите текст сообщения..." required></textarea>
                </div>

                <div class="form-group">
                    <label for="priority"><i class="fas fa-exclamation-circle"></i>Приоритет</label>
                    <select id="priority" name="priority">
                        <option value="low">Низкий</option>
                        <option value="normal" selected>Обычный</option>
                        <option value="high">Высокий</option>
                        <option value="urgent">Срочный</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <i class="fas fa-paper-plane"></i>Отправить уведомление
                </button>
            </form>
        </div>
<div class="blocked-users-section">
    <h3>
        <i class="fas fa-ban"></i>
        Пользователи, заблокировавшие бота
        <span class="blocked-user-status" style="margin-left: 10px;">
            <%= typeof blockedUsers !== 'undefined' ? blockedUsers : '0' %>
        </span>
    </h3>
    
    <div class="blocked-stats">
        <div class="blocked-stat">
            <div class="blocked-stat-number"><%= typeof blockedUsers !== 'undefined' ? blockedUsers : '0' %></div>
            <div class="blocked-stat-label">Всего заблокировали</div>
        </div>
        <div class="blocked-stat">
            <div class="blocked-stat-number">
                <%= typeof totalUsers !== 'undefined' && typeof blockedUsers !== 'undefined' && totalUsers > 0 ? 
                    ((blockedUsers / totalUsers * 100).toFixed(1)) : '0' %>%
            </div>
            <div class="blocked-stat-label">Процент от всех</div>
        </div>
    </div>

    <!-- ДОБАВЬТЕ ЭТУ КНОПКУ ЗДЕСЬ -->
    <div style="margin: 15px 0; text-align: right;">
        <button class="btn btn-danger-lg" id="deleteAllBlockedBtn">
            <i class="fas fa-trash-alt"></i> Удалить всех заблокированных
        </button>
        <p style="font-size: 0.8rem; color: var(--gray); margin-top: 5px;">
            <i class="fas fa-exclamation-triangle"></i> Внимание: это действие удалит всех пользователей, заблокировавших бота. Действие необратимо!
        </p>
    </div>

    <div class="blocked-users-list">
        <% if (typeof blockedUsersList !== 'undefined' && blockedUsersList && blockedUsersList.length > 0) { %>
            <% blockedUsersList.forEach(function(user, index) { %>
                <div class="blocked-user-item" data-user-id="<%= user.id %>" data-telegram-id="<%= user.telegram_id %>">
                    <div class="blocked-user-info">
                        <div class="blocked-user-name">
                            <%= user.username ? `@${user.username}` : 'Без имени' %>
                        </div>
                        <div class="blocked-user-id">
                            ID: <%= user.telegram_id %>
                        </div>
                        <div class="blocked-user-date">
                            Зарегистрирован: <%= new Date(user.created_at).toLocaleDateString('ru-RU') %>
                        </div>
                    </div>
                    <div class="blocked-user-actions">
                        <span class="blocked-user-status">
                            Заблокирован
                        </span>
                        <button class="btn-sm btn-success unblock-user-btn" 
                                data-user-id="<%= user.id %>"
                                data-telegram-id="<%= user.telegram_id %>"
                                data-username="<%= user.username || 'Без имени' %>">
                            <i class="fas fa-unlock"></i>Разблокировать
                        </button>
                        <button class="btn-sm btn-danger delete-user-btn" 
                                data-user-id="<%= user.id %>"
                                data-telegram-id="<%= user.telegram_id %>"
                                data-username="<%= user.username || 'Без имени' %>">
                            <i class="fas fa-trash"></i>Удалить
                        </button>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="no-blocked-users">
                <i class="fas fa-check-circle" style="font-size: 2rem; margin-bottom: 10px; color: var(--success);"></i>
                <p>Отлично! Нет пользователей, заблокировавших бота</p>
            </div>
        <% } %>
    </div>
</div>

    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="spinner"></div>
        <div class="loading-text" id="loadingText">Sending notifications...</div>
        <div class="progress-bar">
            <div class="progress" id="progressBar"></div>
        </div>
    </div>

    <!-- Results Modal -->
    <div class="results-modal" id="resultsModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title" id="modalTitle">Notification Results</h3>
                <button class="close-modal" id="closeModal">&times;</button>
            </div>
            <div id="resultsContent">
                <!-- Results will be inserted here -->
            </div>
        </div>
    </div>

    <!-- Confirmation Modal -->
    <div class="confirmation-modal" id="confirmationModal">
        <div class="confirmation-content">
            <div class="confirmation-icon danger" id="confirmationIcon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="confirmation-text" id="confirmationText">
                Вы уверены, что хотите выполнить это действие?
            </div>
            <div class="confirmation-buttons">
                <button class="confirm-btn confirm-btn-cancel" id="cancelAction">
                    <i class="fas fa-times"></i>Отмена
                </button>
                <button class="confirm-btn confirm-btn-danger" id="confirmAction">
                    <i class="fas fa-check"></i>Подтвердить
                </button>
            </div>
        </div>
    </div>
 
    </div>
        </div>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('notificationForm');
    const submitBtn = document.getElementById('submitBtn');
    const urgentReminderBtn = document.getElementById('urgentReminderBtn');
    const weekReminderBtn = document.getElementById('weekReminderBtn');
    const bonusReminderBtn = document.getElementById('bonusReminderBtn');
    const loadingOverlay = document.getElementById('loadingOverlay');
    const loadingText = document.getElementById('loadingText');
    const progressBar = document.getElementById('progressBar');
    const resultsModal = document.getElementById('resultsModal');
    const resultsContent = document.getElementById('resultsContent');
    const modalTitle = document.getElementById('modalTitle');
    const closeModal = document.getElementById('closeModal');
    const confirmationModal = document.getElementById('confirmationModal');
    const confirmationText = document.getElementById('confirmationText');
    const confirmationIcon = document.getElementById('confirmationIcon');
    const cancelAction = document.getElementById('cancelAction');
    const confirmAction = document.getElementById('confirmAction');

    let currentAction = null;
    let currentUserData = null;
// Добавьте эту переменную после других объявлений в JavaScript
// Сделайте так:
const deleteAllBlockedBtn = document.getElementById('deleteAllBlockedBtn');
if (deleteAllBlockedBtn) {
    deleteAllBlockedBtn.addEventListener('click', function() {
        const blockedCount = parseInt(document.getElementById('blockedUsers').textContent) || 0;
        
        if (blockedCount === 0) {
            resultsContent.innerHTML = `
                <div class="result-item result-info">
                    <h4><i class="fas fa-info-circle"></i> Нет заблокированных пользователей</h4>
                    <p>В базе нет пользователей, заблокировавших бота.</p>
                </div>
            `;
            modalTitle.textContent = 'Информация';
            resultsModal.classList.add('active');
            return;
        }
        
        showDeleteAllConfirmation(blockedCount);
    });
}

// Функция для показа модального окна подтверждения удаления всех
function showDeleteAllConfirmation(count) {
    currentAction = 'delete_all_blocked';
    
    confirmationText.innerHTML = `
        <h3 style="color: var(--danger); margin-bottom: 15px;">
            <i class="fas fa-exclamation-triangle"></i> ВНИМАНИЕ!
        </h3>
        <p>Вы собираетесь удалить <strong style="color: var(--danger);">${count} пользователей</strong>, которые заблокировали бота.</p>
        <p>Это действие:</p>
        <ul style="text-align: left; margin: 10px 0; padding-left: 20px;">
            <li><strong>НЕОБРАТИМО</strong> - данные будут удалены безвозвратно</li>
            <li>Удалит всех пользователей из раздела "Заблокировавшие бота"</li>
            <li>Не повлияет на других пользователей</li>
        </ul>
        <p style="margin-top: 15px; color: var(--warning);">
            <i class="fas fa-shield-alt"></i> Для продолжения введите подтверждающий код: 
            <strong id="confirmCode">${generateRandomCode()}</strong>
        </p>
        <input type="text" id="confirmCodeInput" 
               placeholder="Введите код подтверждения" 
               style="width: 100%; padding: 10px; margin-top: 10px; 
                      border: 2px solid var(--border); border-radius: 8px;
                      text-align: center; font-weight: bold; letter-spacing: 2px;">
    `;
    
    confirmationIcon.className = 'confirmation-icon danger';
    confirmationIcon.innerHTML = '<i class="fas fa-skull-crossbones"></i>';
    
    confirmAction.className = 'confirm-btn confirm-btn-danger';
    confirmAction.innerHTML = '<i class="fas fa-trash-alt"></i> Удалить всех';
    confirmAction.disabled = true;
    
    confirmationModal.classList.add('active');
    
    // Добавляем обработчик для проверки кода подтверждения
    const codeInput = document.getElementById('confirmCodeInput');
    const confirmCode = document.getElementById('confirmCode').textContent;
    
    codeInput.addEventListener('input', function() {
        confirmAction.disabled = this.value.trim() !== confirmCode;
    });
}

// Функция для генерации случайного кода подтверждения
function generateRandomCode() {
    return Math.floor(100000 + Math.random() * 900000).toString();
}

// Функция для удаления всех заблокированных пользователей
async function deleteAllBlockedUsers() {
    try {
        loadingText.textContent = 'Удаление всех заблокированных пользователей...';
        loadingOverlay.classList.add('active');

        const response = await fetch('/admin/delete-all-blocked?secret=<%= query.secret %>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        });

        const result = await response.json();
        loadingOverlay.classList.remove('active');

        if (result.success) {
            showDeleteAllResults(true, result);
            // Очищаем список заблокированных пользователей
            const blockedList = document.querySelector('.blocked-users-list');
            if (blockedList) {
                blockedList.innerHTML = `
                    <div class="no-blocked-users">
                        <i class="fas fa-check-circle" style="font-size: 2rem; margin-bottom: 10px; color: var(--success);"></i>
                        <p>Все заблокированные пользователи были удалены</p>
                    </div>
                `;
            }
            // Обновляем статистику
            document.getElementById('blockedUsers').textContent = '0';
            updateBlockedStats();
        } else {
            showDeleteAllResults(false, result);
        }

    } catch (error) {
        loadingOverlay.classList.remove('active');
        showDeleteAllResults(false, { error: error.message });
    }
}

// Функция для показа результатов удаления всех
function showDeleteAllResults(success, data) {
    if (success) {
        resultsContent.innerHTML = `
            <div class="result-item result-success">
                <h4><i class="fas fa-check-circle"></i> Успешно удалено!</h4>
                <p><strong>Удалено пользователей:</strong> ${data.deletedCount || 0}</p>
                <p><strong>Статус:</strong> ${data.message || 'Все заблокированные пользователи удалены'}</p>
            </div>
            <div class="result-item result-info">
                <h4><i class="fas fa-info-circle"></i> Статистика базы данных</h4>
                <p><strong>Всего пользователей:</strong> ${data.stats?.totalUsers || 'неизвестно'}</p>
                <p><strong>Осталось заблокированных:</strong> ${data.stats?.remainingBlocked || 0}</p>
                <p><strong>Процент блокировок:</strong> ${data.stats?.blockedPercentage || 0}%</p>
            </div>
        `;
    } else {
        resultsContent.innerHTML = `
            <div class="result-item result-error">
                <h4><i class="fas fa-times-circle"></i> Ошибка удаления</h4>
                <p>Не удалось удалить заблокированных пользователей.</p>
                <p><small>${data.error || 'Неизвестная ошибка'}</small></p>
            </div>
        `;
    }
    
    modalTitle.textContent = success ? 'Удаление завершено' : 'Ошибка удаления';
    resultsModal.classList.add('active');
}

// Обновите обработчик подтверждения действия в конфирмейшн модалке:
confirmAction.addEventListener('click', function() {
    if (currentAction === 'delete_all_blocked') {
        const codeInput = document.getElementById('confirmCodeInput');
        const confirmCode = document.getElementById('confirmCode').textContent;
        
        if (codeInput.value.trim() === confirmCode) {
            deleteAllBlockedUsers();
            confirmationModal.classList.remove('active');
        } else {
            codeInput.style.borderColor = 'var(--danger)';
            codeInput.style.boxShadow = '0 0 0 3px rgba(245, 101, 101, 0.1)';
        }
    } else if (currentAction && currentUserData) {
        manageUser(currentAction, currentUserData.userId, currentUserData.telegramId, currentUserData.username);
        confirmationModal.classList.remove('active');
    }
    
    currentAction = null;
    currentUserData = null;
});

// Обновите также обработчик отмены для сброса кода подтверждения:
cancelAction.addEventListener('click', function() {
    confirmationModal.classList.remove('active');
    currentAction = null;
    currentUserData = null;
    
    // Сбрасываем поле кода подтверждения
    const codeInput = document.getElementById('confirmCodeInput');
    if (codeInput) {
        codeInput.value = '';
        codeInput.style.borderColor = 'var(--border)';
        codeInput.style.boxShadow = 'none';
    }
});
    // Функция для показа ошибки
    function showError(message, details = '') {
        resultsContent.innerHTML = `
            <div class="result-item result-error">
                <h4><i class="fas fa-exclamation-triangle"></i> Ошибка</h4>
                <p>${message}</p>
                ${details ? `<p><small>${details}</small></p>` : ''}
            </div>
            <div class="result-item result-warning">
                <h4><i class="fas fa-lightbulb"></i> Рекомендации</h4>
                <ul>
                    <li>Проверьте критерии выбора пользователей</li>
                    <li>Убедитесь, что в базе есть пользователи с нужными характеристиками</li>
                    <li>Попробуйте выбрать другую группу пользователей</li>
                </ul>
            </div>
        `;
        modalTitle.textContent = 'Ошибка отправки';
        resultsModal.classList.add('active');
    }

    // Общая функция для отправки уведомлений
    async function sendNotification(data, title) {
        try {
            loadingText.textContent = `Отправка ${title.toLowerCase()}...`;
            loadingOverlay.classList.add('active');
            
            // Блокируем кнопки
            [urgentReminderBtn, weekReminderBtn, bonusReminderBtn, submitBtn].forEach(btn => {
                if (btn) btn.disabled = true;
            });

            // Симуляция прогресса
            let progress = 0;
            const progressInterval = setInterval(() => {
                progress += Math.random() * 15;
                if (progress >= 85) {
                    clearInterval(progressInterval);
                }
                progressBar.style.width = `${progress}%`;
            }, 200);

            const response = await fetch('/admin/notify?secret=<%= query.secret %>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams(data)
            });

            clearInterval(progressInterval);
            progressBar.style.width = '100%';

            // Проверяем статус ответа перед парсингом JSON
            if (!response.ok) {
                let errorText = await response.text();
                console.error('Server response error:', response.status, errorText);
                
                try {
                    const errorData = JSON.parse(errorText);
                    throw new Error(errorData.error || errorData.message || `HTTP ${response.status}`);
                } catch (e) {
                    throw new Error(`Server error: ${response.status}`);
                }
            }

            const result = await response.json();
            
            setTimeout(() => {
                loadingOverlay.classList.remove('active');
                [urgentReminderBtn, weekReminderBtn, bonusReminderBtn, submitBtn].forEach(btn => {
                    if (btn) btn.disabled = false;
                });

                if (!result.ok) {
                    if (result.error && result.error.includes('No users found')) {
                        showError(
                            'Не найдено пользователей по выбранным критериям',
                            `Критерий: ${getCriteriaName(data.recipients)}\n\n` +
                            `Всего пользователей в базе: ${result.details?.totalUsersInDatabase || 'неизвестно'}\n` +
                            `Активных пользователей: ${result.details?.activeUsers || 'неизвестно'}`
                        );
                    } else {
                        showError(
                            result.message || result.error || 'Произошла ошибка при отправке',
                            result.details ? JSON.stringify(result.details, null, 2) : ''
                        );
                    }
                    return;
                }

                showResults(result);
            }, 800);

        } catch (error) {
            loadingOverlay.classList.remove('active');
            [urgentReminderBtn, weekReminderBtn, bonusReminderBtn, submitBtn].forEach(btn => {
                if (btn) btn.disabled = false;
            });
            
            console.error('Notification error:', error);
            showError('Ошибка сети или сервера', error.message);
        }
    }

    // Функция для управления пользователями (разблокировка/удаление)
    async function manageUser(action, userId, telegramId, username) {
        try {
            loadingText.textContent = action === 'unblock' ? 'Разблокировка пользователя...' : 'Удаление пользователя...';
            loadingOverlay.classList.add('active');

            const response = await fetch('/admin/manage-user?secret=<%= query.secret %>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    action: action,
                    userId: userId,
                    telegramId: telegramId
                })
            });

            const result = await response.json();

            loadingOverlay.classList.remove('active');

            if (result.success) {
                showUserManagementResult(true, action, username, result.message);
                // Удаляем элемент из списка
                const userElement = document.querySelector(`[data-user-id="${userId}"]`);
                if (userElement) {
                    userElement.remove();
                }
                // Обновляем статистику
                updateBlockedStats();
            } else {
                showUserManagementResult(false, action, username, result.error);
            }

        } catch (error) {
            loadingOverlay.classList.remove('active');
            showUserManagementResult(false, action, username, error.message);
        }
    }

    // Функция показа результатов управления пользователями
    function showUserManagementResult(success, action, username, message) {
        const actionText = action === 'unblock' ? 'разблокировка' : 'удаление';
        const actionPast = action === 'unblock' ? 'разблокирован' : 'удален';
        
        if (success) {
            resultsContent.innerHTML = `
                <div class="result-item result-success">
                    <h4><i class="fas fa-check-circle"></i> Успешно!</h4>
                    <p>Пользователь <strong>${username}</strong> успешно ${actionPast}.</p>
                    <p><small>${message || ''}</small></p>
                </div>
            `;
        } else {
            resultsContent.innerHTML = `
                <div class="result-item result-error">
                    <h4><i class="fas fa-times-circle"></i> Ошибка</h4>
                    <p>Не удалось выполнить ${actionText} пользователя <strong>${username}</strong>.</p>
                    <p><small>${message || 'Неизвестная ошибка'}</small></p>
                </div>
            `;
        }
        
        modalTitle.textContent = `Результат ${actionText}`;
        resultsModal.classList.add('active');
    }

    // Функция показа модального окна подтверждения
    function showConfirmation(action, userData) {
        currentAction = action;
        currentUserData = userData;
        
        const actionText = action === 'unblock' ? 'разблокировать' : 'удалить';
        const actionColor = action === 'unblock' ? 'success' : 'danger';
        const actionIcon = action === 'unblock' ? 'fa-unlock' : 'fa-trash';
        
        confirmationText.innerHTML = `
            Вы уверены, что хотите ${actionText} пользователя <strong>${userData.username}</strong>?
            ${action === 'delete' ? '<br><br><small style="color: var(--danger);"><i class="fas fa-exclamation-triangle"></i> Это действие невозможно отменить! Все данные пользователя будут удалены безвозвратно.</small>' : ''}
        `;
        
        confirmationIcon.className = 'confirmation-icon ' + actionColor;
        confirmationIcon.innerHTML = `<i class="fas ${actionIcon}"></i>`;
        
        confirmAction.className = `confirm-btn confirm-btn-${actionColor}`;
        confirmAction.innerHTML = `<i class="fas fa-check"></i>${action === 'unblock' ? 'Разблокировать' : 'Удалить'}`;
        
        confirmationModal.classList.add('active');
    }

    // Обработчики для кнопок управления пользователями
    document.addEventListener('click', function(e) {
        if (e.target.classList.contains('unblock-user-btn') || e.target.closest('.unblock-user-btn')) {
            const btn = e.target.classList.contains('unblock-user-btn') ? e.target : e.target.closest('.unblock-user-btn');
            const userId = btn.dataset.userId;
            const telegramId = btn.dataset.telegramId;
            const username = btn.dataset.username;
            
            showConfirmation('unblock', { userId, telegramId, username });
        }
        
        if (e.target.classList.contains('delete-user-btn') || e.target.closest('.delete-user-btn')) {
            const btn = e.target.classList.contains('delete-user-btn') ? e.target : e.target.closest('.delete-user-btn');
            const userId = btn.dataset.userId;
            const telegramId = btn.dataset.telegramId;
            const username = btn.dataset.username;
            
            showConfirmation('delete', { userId, telegramId, username });
        }
    });

    // Обработчики для модального окна подтверждения
    confirmAction.addEventListener('click', function() {
        if (currentAction && currentUserData) {
            manageUser(currentAction, currentUserData.userId, currentUserData.telegramId, currentUserData.username);
            confirmationModal.classList.remove('active');
        }
    });

    cancelAction.addEventListener('click', function() {
        confirmationModal.classList.remove('active');
        currentAction = null;
        currentUserData = null;
    });

    // Закрытие модального окна подтверждения по клику вне его
    confirmationModal.addEventListener('click', function(e) {
        if (e.target === confirmationModal) {
            confirmationModal.classList.remove('active');
            currentAction = null;
            currentUserData = null;
        }
    });

    // Быстрая рассылка - срочное напоминание
    urgentReminderBtn.addEventListener('click', function() {
        const userCount = parseInt(document.getElementById('urgentSubscriptions').textContent) || 0;
        
        if (userCount === 0) {
            showError(
                'Нет пользователей для срочного напоминания',
                'В настоящее время нет пользователей с 1-3 днями до окончания подписки'
            );
            return;
        }

        if (!confirm(`Отправить срочные напоминания ${userCount} пользователям с 1-3 днями до окончания подписки?`)) {
            return;
        }
        
        sendNotification({
            recipients: 'urgent_subscription',
            message: getUrgentReminderMessage(),
            messageType: 'alert',
            priority: 'urgent'
        }, 'Срочное напоминание о подписке');
    });

    // Быстрая рассылка - напоминание за неделю
    weekReminderBtn.addEventListener('click', function() {
        const userCount = parseInt(document.getElementById('expiringSubscriptions').textContent) || 0;
        
        if (userCount === 0) {
            showError(
                'Нет пользователей для напоминания',
                'В настоящее время нет пользователей с истекающей подпиской'
            );
            return;
        }

        if (!confirm(`Отправить напоминания ${userCount} пользователям с 4-7 днями до окончания подписки?`)) {
            return;
        }
        
        sendNotification({
            recipients: 'expiring_subscription',
            message: getWeekReminderMessage(),
            messageType: 'update',
            priority: 'high'
        }, 'Напоминание о подписке');
    });

    // Бонус для новых пользователей
    bonusReminderBtn.addEventListener('click', function() {
        const userCount = parseInt(document.getElementById('noInvestmentsUsers').textContent) || 0;
        
        if (userCount === 0) {
            showError(
                'Нет пользователей для бонусной рассылки',
                'В настоящее время нет пользователей без инвестиций'
            );
            return;
        }

        if (!confirm(`Отправить бонусные предложения ${userCount} пользователям без инвестиций?`)) {
            return;
        }
        
        sendNotification({
            recipients: 'no_investments',
            message: getBonusMessage(),
            messageType: 'promotion',
            priority: 'normal'
        }, 'Бонусное предложение');
    });

    // Обработка ручной формы
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const message = document.getElementById('message').value;
        const messageType = document.getElementById('messageType').value;
        const recipients = document.getElementById('recipients').value;
        const priority = document.getElementById('priority').value;

        if (!message || message.trim() === '') {
            alert('Пожалуйста, введите текст сообщения');
            return;
        }

        sendNotification({
            message: message,
            messageType: messageType,
            recipients: recipients,
            priority: priority
        }, 'Уведомление');
    });

    // Вспомогательные функции
    function getCriteriaName(criteria) {
        const criteriaMap = {
            'all': 'Все пользователи',
            'active': 'Активные пользователи',
            'inactive': 'Неактивные пользователи',
            'premium': 'Премиум пользователи',
            'no_investments': 'Пользователи без инвестиций',
            'with_investments': 'Пользователи с инвестициями',
            'expired_subscription': 'Подписка истекла',
            'expiring_subscription': 'Подписка истекает скоро',
            'urgent_subscription': 'Срочно: 1-3 дня до конца'
        };
        return criteriaMap[criteria] || criteria;
    }

    function getUrgentReminderMessage() {
        return `⚠️ СРОЧНОЕ УВЕДОМЛЕНИЕ ⚠️

Ваша подписка заканчивается через 1-3 дня!

Продлите подписку сейчас, чтобы сохранить доступ ко всем премиум-функциям и продолжить заработок.

Не упустите возможность увеличить свой доход!`;
    }

    function getWeekReminderMessage() {
        return `🔔 НАПОМИНАНИЕ О ПОДПИСКЕ

Ваша подписка истекает через 4-7 дней.

Рекомендуем продлить подписку заранее, чтобы не прерывать ваш инвестиционный процесс.

Продолжайте зарабатывать с нами!`;
    }

    function getBonusMessage() {
        return `🎁 СПЕЦИАЛЬНОЕ ПРЕДЛОЖЕНИЕ ДЛЯ НОВЫХ ПОЛЬЗОВАТЕЛЕЙ!

Получите бонус $10,000 для начала инвестирования!

Начните свой путь к финансовой свободе с нашим специальным бонусным предложением.

Не упустите эту уникальную возможность!`;
    }

    // Обновленная функция показа результатов с выводом заблокированных пользователей
    function showResults(data) {
        let html = '';
        
        if (data.success || data.ok) {
            html += `
                <div class="result-item result-success">
                    <h4><i class="fas fa-check-circle"></i> Уведомления отправлены успешно!</h4>
                    <p>${data.message || 'Рассылка успешно завершена'}</p>
                    ${data.sentCount ? `<p><strong>Успешно отправлено:</strong> ${data.sentCount} пользователей</p>` : ''}
                    ${data.failedCount ? `<p><strong>Не удалось отправить:</strong> ${data.failedCount}</p>` : ''}
                    ${data.blockedCount ? `<p><strong>Заблокировали бота:</strong> ${data.blockedCount}</p>` : ''}
                    ${data.totalUsers ? `<p><strong>Всего пользователей в выборке:</strong> ${data.totalUsers}</p>` : ''}
                </div>`;
                
            if (data.personalized) {
                html += `<div class="result-item result-info">
                    <p><i class="fas fa-magic"></i> <strong>Сообщения были персонализированы</strong></p>
                </div>`;
            }

            // Показываем список заблокированных пользователей, если они есть
            if (data.blockedUsers && data.blockedUsers.length > 0) {
                html += `
                <div class="blocked-results">
                    <h4><i class="fas fa-user-slash"></i> Пользователи, заблокировавшие бота (${data.blockedCount})</h4>
                    <p style="margin-bottom: 10px; font-size: 0.9rem; color: var(--gray);">
                        Эти пользователи не получили сообщение, так как заблокировали бота:
                    </p>
					<!-- Добавьте эту разметку в блок .blocked-users-section после .blocked-stats -->
<div style="margin: 15px 0; text-align: right;">
    <button class="btn btn-danger" id="deleteAllBlockedBtn">
        <i class="fas fa-trash-alt"></i> Удалить всех заблокированных
    </button>
    <p style="font-size: 0.8rem; color: var(--gray); margin-top: 5px;">
        <i class="fas fa-exclamation-triangle"></i> Внимание: это действие удалит всех пользователей, заблокировавших бота. Действие необратимо!
    </p>
</div>
                    <div class="blocked-results-list">`;
                
                data.blockedUsers.forEach(user => {
                    html += `
                        <div class="blocked-result-item">
                            <div>
                                <strong>${user.username || 'Без имени'}</strong>
                                <div style="font-size: 0.8rem; color: var(--gray);">ID: ${user.userId}</div>
                            </div>
                            <div style="font-size: 0.8rem; color: var(--danger); font-weight: 600;">
                                Заблокирован
                            </div>
                        </div>`;
                });
                
                html += `</div></div>`;
            }

            // Показываем список неудачных отправок, если они есть
            if (data.failedUsers && data.failedUsers.length > 0) {
                html += `
                <div class="result-item result-warning">
                    <h4><i class="fas fa-exclamation-triangle"></i> Неудачные отправки (${data.failedCount})</h4>
                    <p style="margin-bottom: 10px; font-size: 0.9rem; color: var(--gray);">
                        Эти пользователи не получили сообщение по другим причинам:
                    </p>
                    <div style="max-height: 150px; overflow-y: auto; margin-top: 10px;">`;
                
                data.failedUsers.forEach(user => {
                    html += `
                        <div style="padding: 8px 0; border-bottom: 1px solid var(--border);">
                            <div style="display: flex; justify-content: space-between; align-items: start;">
                                <div>
                                    <strong>${user.username || 'Без имени'}</strong>
                                    <div style="font-size: 0.8rem; color: var(--gray);">ID: ${user.userId}</div>
                                </div>
                                <div style="font-size: 0.8rem; color: var(--warning); font-weight: 600;">
                                    Ошибка
                                </div>
                            </div>
                            <div style="font-size: 0.8rem; color: var(--gray); margin-top: 5px;">
                                <strong>Причина:</strong> ${user.reason}
                            </div>
                        </div>`;
                });
                
                html += `</div></div>`;
            }

            // Показываем статистику доставки
            const successRate = data.totalUsers > 0 ? ((data.sentCount / data.totalUsers) * 100).toFixed(1) : 0;
            html += `
            <div class="result-item result-info">
                <h4><i class="fas fa-chart-pie"></i> Статистика доставки</h4>
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 10px;">
                    <div style="text-align: center; padding: 10px; background: rgba(72, 187, 120, 0.1); border-radius: 8px;">
                        <div style="font-size: 1.2rem; font-weight: bold; color: var(--success);">${data.sentCount || 0}</div>
                        <div style="font-size: 0.8rem; color: var(--dark);">Успешно</div>
                    </div>
                    <div style="text-align: center; padding: 10px; background: rgba(245, 101, 101, 0.1); border-radius: 8px;">
                        <div style="font-size: 1.2rem; font-weight: bold; color: var(--danger);">${data.blockedCount || 0}</div>
                        <div style="font-size: 0.8rem; color: var(--dark);">Заблокировали</div>
                    </div>
                    <div style="text-align: center; padding: 10px; background: rgba(237, 137, 54, 0.1); border-radius: 8px;">
                        <div style="font-size: 1.2rem; font-weight: bold; color: var(--warning);">${data.failedCount || 0}</div>
                        <div style="font-size: 0.8rem; color: var(--dark);">Ошибки</div>
                    </div>
                </div>
                <div style="margin-top: 10px; text-align: center;">
                    <div style="font-size: 0.9rem; color: var(--dark);">
                        <strong>Процент доставки:</strong> ${successRate}%
                    </div>
                </div>
            </div>`;

        } else {
            html += `
                <div class="result-item result-error">
                    <h4><i class="fas fa-times-circle"></i> Ошибка отправки</h4>
                    <p>${data.message || data.error || 'Произошла неизвестная ошибка'}</p>
                </div>`;
        }
        
        resultsContent.innerHTML = html;
        modalTitle.textContent = 'Результаты рассылки';
        resultsModal.classList.add('active');
    }

    // Функция для обновления статистики блокировок на странице
    function updateBlockedStats() {
        const totalUsers = parseInt(document.getElementById('totalUsers').textContent) || 0;
        const blockedUsers = parseInt(document.getElementById('blockedUsers').textContent) || 0;
        
        // Обновляем процент блокировок если есть элемент для этого
        const percentageElement = document.querySelector('.blocked-stat-number:last-child');
        if (percentageElement && totalUsers > 0) {
            const blockedPercentage = ((blockedUsers / totalUsers) * 100).toFixed(1);
            percentageElement.textContent = `${blockedPercentage}%`;
        }

        // Обновляем счетчик заблокированных пользователей
        const blockedCountElement = document.querySelector('.blocked-users-section .blocked-user-status');
        if (blockedCountElement) {
            // Пересчитываем количество оставшихся заблокированных пользователей
            const remainingBlockedUsers = document.querySelectorAll('.blocked-user-item').length;
            blockedCountElement.textContent = remainingBlockedUsers;
            document.getElementById('blockedUsers').textContent = remainingBlockedUsers;
        }
    }

    // Закрытие модального окна
    closeModal.addEventListener('click', function() {
        resultsModal.classList.remove('active');
    });
    
    resultsModal.addEventListener('click', function(e) {
        if (e.target === resultsModal) {
            resultsModal.classList.remove('active');
        }
    });

    // Инициализация при загрузке страницы
    updateBlockedStats();
});
</script>
</body>
</html>