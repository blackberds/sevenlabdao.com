                <!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bitnest — Децентрализованная платформа</title>
    <style>
        :root {
            --primary: #2962FF;
            --primary-dark: #0039CB;
            --secondary: #FF6D00;
            --dark: #1A1A2E;
            --darker: #0F0F23;
            --light: #F5F5F7;
            --gray: #707084;
            --success: #00C853;
            --warning: #FFAB00;
            --danger: #FF1744;
            --card-bg: rgba(255, 255, 255, 0.05);
            --card-border: rgba(255, 255, 255, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(180deg, var(--darker) 0%, var(--dark) 100%);
            color: var(--light);
            min-height: 100vh;
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            margin-bottom: 30px;
            border-bottom: 1px solid var(--card-border);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo-icon {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            box-shadow: 0 5px 20px rgba(41, 98, 255, 0.3);
        }

        .logo-text {
            font-size: 24px;
            font-weight: 700;
            background: linear-gradient(135deg, #FFFFFF 0%, #E0E0E0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .user-menu {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-avatar {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: var(--card-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--card-border);
            font-size: 20px;
        }

        .balance {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            padding: 10px 15px;
            font-weight: 600;
        }

        /* Navigation */
        .nav-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            overflow-x: auto;
            padding-bottom: 10px;
        }

        .nav-tab {
            padding: 12px 20px;
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            cursor: pointer;
            white-space: nowrap;
            transition: all 0.3s ease;
        }

        .nav-tab.active {
            background: var(--primary);
            border-color: var(--primary);
        }

        .nav-tab:hover {
            background: rgba(41, 98, 255, 0.2);
        }

        /* Content Sections */
        .section {
            display: none;
            animation: fadeIn 0.3s ease;
        }

        .section.active {
            display: block;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 20px;
        }

        .card-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card-icon {
            font-size: 24px;
        }

        /* Wallet Section */
        .wallet-address {
            background: rgba(0, 0, 0, 0.2);
            padding: 12px;
            border-radius: 8px;
            font-family: monospace;
            margin-bottom: 20px;
            word-break: break-all;
        }

        .balance-cards {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .balance-card {
            background: linear-gradient(135deg, rgba(41, 98, 255, 0.1) 0%, rgba(0, 57, 203, 0.1) 100%);
            border: 1px solid rgba(41, 98, 255, 0.2);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
        }

        .balance-amount {
            font-size: 24px;
            font-weight: 700;
            margin: 10px 0;
        }

        .balance-label {
            color: var(--gray);
            font-size: 14px;
        }

        /* Buttons */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 20px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .btn:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .btn-success {
            background: var(--success);
        }

        .btn-warning {
            background: var(--warning);
        }

        .btn-danger {
            background: var(--danger);
        }

        /* Forms */
        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .form-input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            color: var(--light);
            font-size: 16px;
        }

        .form-input:focus {
            outline: none;
            border-color: var(--primary);
        }

        /* Raffle Section */
        .raffle-info {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .raffle-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
        }

        .raffle-value {
            font-size: 20px;
            font-weight: 700;
            margin: 10px 0;
        }

        /* Investment Section */
        .investment-options {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .investment-option {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .investment-option:hover {
            border-color: var(--primary);
            transform: translateY(-5px);
        }

        .investment-option.selected {
            background: linear-gradient(135deg, rgba(41, 98, 255, 0.1) 0%, rgba(0, 57, 203, 0.1) 100%);
            border-color: var(--primary);
        }

        .investment-return {
            color: var(--success);
            font-weight: 600;
        }

        /* Referral Section */
        .referral-stats {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .referral-stat {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
        }

        .stat-value {
            font-size: 24px;
            font-weight: 700;
            margin: 10px 0;
        }

        .stat-label {
            color: var(--gray);
            font-size: 14px;
        }

        .level-badge {
            display: inline-block;
            padding: 4px 10px;
            background: var(--primary);
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        /* Admin Section */
        .admin-controls {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .admin-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .admin-card:hover {
            border-color: var(--primary);
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }
            
            .balance-cards,
            .raffle-info,
            .investment-options,
            .referral-stats,
            .admin-controls {
                grid-template-columns: 1fr;
            }
            
            .nav-tabs {
                flex-wrap: nowrap;
                overflow-x: auto;
            }
        }

        /* Loading */
        .loading {
            display: none;
            text-align: center;
            padding: 40px 0;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 4px solid rgba(255, 255, 255, 0.1);
            border-top: 4px solid var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px auto;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Notifications */
        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 15px 20px;
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.2);
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 1000;
            transform: translateX(100%);
            transition: transform 0.3s ease;
        }

        .notification.show {
            transform: translateX(0);
        }

        .notification.success {
            border-left: 4px solid var(--success);
        }

        .notification.error {
            border-left: 4px solid var(--danger);
        }

        .notification.warning {
            border-left: 4px solid var(--warning);
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <header class="header">
            <div class="logo">
                <div class="logo-icon">B</div>
                <div class="logo-text">Bitnest</div>
            </div>
            <div class="user-menu">
                <div class="balance" id="userBalance">0.00 USDT</div>
                <div class="user-avatar" id="userAvatar">U</div>
            </div>
        </header>

        <!-- Navigation Tabs -->
        <nav class="nav-tabs">
            <div class="nav-tab active" data-section="dashboard">Главная</div>
            <div class="nav-tab" data-section="wallet">Кошелек</div>
            <div class="nav-tab" data-section="raffle">Розыгрыш</div>
            <div class="nav-tab" data-section="liquidity">Пул ликвидности</div>
            <div class="nav-tab" data-section="referral">Партнерская программа</div>
            <div class="nav-tab" data-section="settings">Настройки</div>
            <div class="nav-tab" data-section="admin" id="adminTab" style="display: none;">Админ-панель</div>
        </nav>

        <!-- Notification -->
        <div class="notification" id="notification">
            <span id="notificationMessage"></span>
        </div>

        <!-- Loading -->
        <div class="loading" id="loading">
            <div class="spinner"></div>
            <p>Загрузка...</p>
        </div>

        <!-- Dashboard Section -->
        <section id="dashboard" class="section active">
            <div class="card">
                <h2 class="card-title"><span class="card-icon">🏠</span> Добро пожаловать в Bitnest</h2>
                <p>Децентрализованная платформа для инвестиций и заработка</p>
                
                <div class="balance-cards">
                    <div class="balance-card">
                        <div class="balance-label">Баланс USDT</div>
                        <div class="balance-amount" id="dashboardBalance">0.00</div>
                    </div>
                    <div class="balance-card">
                        <div class="balance-label">Баланс BNB</div>
                        <div class="balance-amount" id="dashboardBnb">0.00</div>
                    </div>
                    <div class="balance-card">
                        <div class="balance-label">Активные инвестиции</div>
                        <div class="balance-amount" id="activeInvestments">0.00 USDT</div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px; margin-top: 20px;">
                    <button class="btn" onclick="showSection('wallet')">💼 Мой кошелек</button>
                    <button class="btn" onclick="showSection('raffle')">🎯 Розыгрыш</button>
                    <button class="btn" onclick="showSection('liquidity')">💧 Пул ликвидности</button>
                    <button class="btn" onclick="showSection('referral')">👥 Партнерская программа</button>
                </div>
            </div>
        </section>

        <!-- Wallet Section -->
        <section id="wallet" class="section">
            <div class="card">
                <h2 class="card-title"><span class="card-icon">💼</span> Мой кошелек</h2>
                
                <div class="form-group">
                    <label class="form-label">Адрес кошелька</label>
                    <div class="wallet-address" id="walletAddress">Не настроен</div>
                </div>

                <div class="balance-cards">
                    <div class="balance-card">
                        <div class="balance-label">Баланс USDT</div>
                        <div class="balance-amount" id="walletUsdt">0.00</div>
                        <button class="btn btn-secondary" style="margin-top: 10px;" onclick="refreshBalances()">🔄 Обновить</button>
                    </div>
                    <div class="balance-card">
                        <div class="balance-label">Баланс BNB</div>
                        <div class="balance-amount" id="walletBnb">0.00</div>
                    </div>
                </div>

                <div style="margin-top: 20px;">
                    <button class="btn" onclick="connectWallet()">🔗 Подключить кошелек</button>
                </div>
            </div>
        </section>

        <!-- Raffle Section -->
        <section id="raffle" class="section">
            <div class="card">
                <h2 class="card-title"><span class="card-icon">🎯</span> Розыгрыш</h2>
                
                <div class="raffle-info">
                    <div class="raffle-card">
                        <div class="balance-label">Текущий раунд</div>
                        <div class="raffle-value" id="raffleRound">#1</div>
                    </div>
                    <div class="raffle-card">
                        <div class="balance-label">Призовой фонд</div>
                        <div class="raffle-value" id="rafflePrize">0 USDT</div>
                    </div>
                    <div class="raffle-card">
                        <div class="balance-label">Участников</div>
                        <div class="raffle-value" id="raffleParticipants">0</div>
                    </div>
                    <div class="raffle-card">
                        <div class="balance-label">До окончания</div>
                        <div class="raffle-value" id="raffleTime">00:00:00</div>
                    </div>
                </div>

                <div id="raffleStatus">
                    <p>Для участия в розыгрыше необходимо настроить кошелек и иметь минимальный баланс.</p>
                </div>

                <div style="margin-top: 20px;">
                    <button class="btn" id="participateBtn" onclick="participateInRaffle()" disabled>Участвовать в розыгрыше</button>
                    <button class="btn btn-secondary" onclick="checkRaffleStatus()">🔄 Проверить статус</button>
                </div>
            </div>
        </section>

        <!-- Liquidity Pool Section -->
        <section id="liquidity" class="section">
            <div class="card">
                <h2 class="card-title"><span class="card-icon">💧</span> Пул ликвидности</h2>
                
                <div class="balance-cards">
                    <div class="balance-card">
                        <div class="balance-label">Мои инвестиции</div>
                        <div class="balance-amount" id="myInvestments">0.00 USDT</div>
                    </div>
                    <div class="balance-card">
                        <div class="balance-label">Общий пул</div>
                        <div class="balance-amount" id="totalPool">0.00 USDT</div>
                    </div>
                    <div class="balance-card">
                        <div class="balance-label">Доходность</div>
                        <div class="balance-amount">0.4% - 24%</div>
                    </div>
                </div>

                <h3 style="margin: 20px 0 15px 0;">Выберите сумму инвестирования</h3>
                
                <div class="investment-options">
                    <div class="investment-option" data-amount="100">
                        <div class="balance-label">100 USDT</div>
                        <div class="investment-return">+0.4% - 24%</div>
                    </div>
                    <div class="investment-option" data-amount="500">
                        <div class="balance-label">500 USDT</div>
                        <div class="investment-return">+0.4% - 24%</div>
                    </div>
                    <div class="investment-option" data-amount="1000">
                        <div class="balance-label">1000 USDT</div>
                        <div class="investment-return">+0.4% - 24%</div>
                    </div>
                    <div class="investment-option" data-amount="custom">
                        <div class="balance-label">Своя сумма</div>
                        <div class="investment-return">+0.4% - 24%</div>
                    </div>
                </div>

                <div id="customAmountSection" style="display: none; margin-top: 20px;">
                    <div class="form-group">
                        <label class="form-label">Введите сумму в USDT</label>
                        <input type="number" class="form-input" id="customAmount" placeholder="Минимум 1 USDT">
                    </div>
                </div>

                <h3 style="margin: 20px 0 15px 0;">Выберите срок инвестирования</h3>
                
                <div class="investment-options">
                    <div class="investment-option" data-days="1">
                        <div class="balance-label">1 день</div>
                        <div class="investment-return">+0.4%</div>
                    </div>
                    <div class="investment-option" data-days="7">
                        <div class="balance-label">7 дней</div>
                        <div class="investment-return">+4%</div>
                    </div>
                    <div class="investment-option" data-days="14">
                        <div class="balance-label">14 дней</div>
                        <div class="investment-return">+9.5%</div>
                    </div>
                    <div class="investment-option" data-days="28">
                        <div class="balance-label">28 дней</div>
                        <div class="investment-return">+24%</div>
                    </div>
                </div>

                <div id="investmentSummary" style="margin-top: 20px; padding: 15px; background: rgba(0,0,0,0.1); border-radius: 12px; display: none;">
                    <h4>Детали инвестиции</h4>
                    <p>Сумма: <span id="summaryAmount">0</span> USDT</p>
                    <p>Срок: <span id="summaryDays">0</span> дней</p>
                    <p>Ожидаемый доход: <span id="summaryProfit">0</span> USDT</p>
                    <p>Общая сумма возврата: <span id="summaryTotal">0</span> USDT</p>
                </div>

                <div style="margin-top: 20px;">
                    <button class="btn" id="investBtn" onclick="processInvestment()" disabled>💸 Инвестировать</button>
                    <button class="btn btn-secondary" onclick="showSection('wallet')">💼 Мой портфель</button>
                </div>
            </div>
        </section>

        <!-- Referral Section -->
        <section id="referral" class="section">
            <div class="card">
                <h2 class="card-title"><span class="card-icon">👥</span> Партнерская программа</h2>
                
                <div class="referral-stats">
                    <div class="referral-stat">
                        <div class="stat-label">Всего рефералов</div>
                        <div class="stat-value" id="totalReferrals">0</div>
                    </div>
                    <div class="referral-stat">
                        <div class="stat-label">Активировано уровней</div>
                        <div class="stat-value" id="activeLevels">0/17</div>
                    </div>
                    <div class="referral-stat">
                        <div class="stat-label">Реферальный доход</div>
                        <div class="stat-value" id="referralIncome">0 USDT</div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Ваша реферальная ссылка</label>
                    <div class="wallet-address" id="referralLink">https://bitnest.ad/RQTPT</div>
                    <button class="btn btn-secondary" style="margin-top: 10px;" onclick="copyReferralLink()">📋 Скопировать ссылку</button>
                </div>

                <h3 style="margin: 20px 0 15px 0;">Уровни партнерской программы</h3>
                
                <div style="margin-bottom: 20px;">
                    <p>Активируйте уровни, увеличивая свою долю в пуле ликвидности:</p>
                    <p>Уровень 1: 100$ | Уровень 2: 200$ | ... | Уровень 17: 1700$</p>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px;">
                    <button class="btn" onclick="showReferralDetails()">📊 Детальная статистика</button>
                    <button class="btn btn-secondary" onclick="showLevelInfo()">🔓 Информация об уровнях</button>
                </div>
            </div>
        </section>

        <!-- Settings Section -->
        <section id="settings" class="section">
            <div class="card">
                <h2 class="card-title"><span class="card-icon">⚙️</span> Настройки</h2>
                
                <div class="form-group">
                    <label class="form-label">Язык / Language</label>
                    <select class="form-input" id="languageSelect">
                        <option value="ru">Русский</option>
                        <option value="en">English</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Уведомления</label>
                    <div>
                        <input type="checkbox" id="notificationsEnabled" checked>
                        <label for="notificationsEnabled">Получать уведомления</label>
                    </div>
                </div>

                <h3 style="margin: 20px 0 15px 0;">Безопасность</h3>
                
                <div style="margin-bottom: 20px;">
                    <button class="btn btn-secondary" onclick="disconnectWallet()">🔒 Отключить кошелек</button>
                </div>

                <h3 style="margin: 20px 0 15px 0;">Поддержка</h3>
                
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px;">
                    <button class="btn btn-secondary" onclick="contactSupport()">💬 Связаться с поддержкой</button>
                    <button class="btn btn-secondary" onclick="openHelp()">❓ Помощь и инструкции</button>
                </div>
            </div>
        </section>

        <!-- Admin Section -->
        <section id="admin" class="section">
            <div class="card">
                <h2 class="card-title"><span class="card-icon">🔧</span> Админ-панель</h2>
                
                <div class="admin-controls">
                    <div class="admin-card" onclick="adminSetPrize()">
                        <div class="card-icon">🎁</div>
                        <h3>Установить приз</h3>
                        <p>Изменение призового фонда розыгрыша</p>
                    </div>
                    <div class="admin-card" onclick="adminSetTimes()">
                        <div class="card-icon">⏰</div>
                        <h3>Установить время</h3>
                        <p>Настройка времени розыгрыша</p>
                    </div>
                    <div class="admin-card" onclick="adminTogglePause()">
                        <div class="card-icon">⏯️</div>
                        <h3>Приостановить</h3>
                        <p>Включение/выключение розыгрыша</p>
                    </div>
                    <div class="admin-card" onclick="adminSelectWinner()">
                        <div class="card-icon">🎲</div>
                        <h3>Выбрать победителя</h3>
                        <p>Запуск выбора победителя</p>
                    </div>
                </div>

                <h3 style="margin: 20px 0 15px 0;">Статистика</h3>
                
                <div class="referral-stats">
                    <div class="referral-stat">
                        <div class="stat-label">Всего пользователей</div>
                        <div class="stat-value" id="adminTotalUsers">0</div>
                    </div>
                    <div class="referral-stat">
                        <div class="stat-label">Активных розыгрышей</div>
                        <div class="stat-value" id="adminActiveRaffles">0</div>
                    </div>
                    <div class="referral-stat">
                        <div class="stat-label">Общий объем пула</div>
                        <div class="stat-value" id="adminTotalPool">0 USDT</div>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <script>
        // Глобальные переменные
        let userData = null;
        let selectedAmount = 0;
        let selectedDays = 0;
        let isAdmin = false;

        // Инициализация при загрузке
        document.addEventListener('DOMContentLoaded', function() {
            // Проверяем, есть ли сохраненные данные пользователя
            const savedUserData = localStorage.getItem('bitnest_user');
            if (savedUserData) {
                userData = JSON.parse(savedUserData);
                updateUI();
            }
            
            // Проверяем, является ли пользователь администратором
            checkAdminStatus();
            
            // Загружаем данные розыгрыша
            loadRaffleData();
            
            // Инициализируем обработчики событий
            initEventListeners();
        });

        // Инициализация обработчиков событий
        function initEventListeners() {
            // Навигационные вкладки
            const tabs = document.querySelectorAll('.nav-tab');
            tabs.forEach(tab => {
                tab.addEventListener('click', function() {
                    const section = this.getAttribute('data-section');
                    showSection(section);
                });
            });
            
            // Опции инвестирования (сумма)
            const amountOptions = document.querySelectorAll('.investment-option[data-amount]');
            amountOptions.forEach(option => {
                option.addEventListener('click', function() {
                    // Сброс предыдущего выбора
                    document.querySelectorAll('.investment-option').forEach(opt => {
                        opt.classList.remove('selected');
                    });
                    
                    this.classList.add('selected');
                    
                    const amount = this.getAttribute('data-amount');
                    if (amount === 'custom') {
                        document.getElementById('customAmountSection').style.display = 'block';
                        selectedAmount = 0;
                    } else {
                        document.getElementById('customAmountSection').style.display = 'none';
                        selectedAmount = parseInt(amount);
                        updateInvestmentSummary();
                    }
                });
            });
            
            // Опции инвестирования (срок)
            const daysOptions = document.querySelectorAll('.investment-option[data-days]');
            daysOptions.forEach(option => {
                option.addEventListener('click', function() {
                    // Сброс предыдущего выбора
                    document.querySelectorAll('.investment-option[data-days]').forEach(opt => {
                        opt.classList.remove('selected');
                    });
                    
                    this.classList.add('selected');
                    selectedDays = parseInt(this.getAttribute('data-days'));
                    updateInvestmentSummary();
                });
            });
            
            // Поле для ввода своей суммы
            document.getElementById('customAmount').addEventListener('input', function() {
                selectedAmount = parseInt(this.value) || 0;
                updateInvestmentSummary();
            });
            
            // Смена языка
            document.getElementById('languageSelect').addEventListener('change', function() {
                changeLanguage(this.value);
            });
        }

        // Показать определенный раздел
        function showSection(sectionId) {
            // Скрыть все разделы
            document.querySelectorAll('.section').forEach(section => {
                section.classList.remove('active');
            });
            
            // Показать выбранный раздел
            document.getElementById(sectionId).classList.add('active');
            
            // Обновить активную вкладку
            document.querySelectorAll('.nav-tab').forEach(tab => {
                tab.classList.remove('active');
            });
            
            document.querySelector(`.nav-tab[data-section="${sectionId}"]`).classList.add('active');
            
            // Загрузить данные для раздела, если необходимо
            if (sectionId === 'raffle') {
                loadRaffleData();
            } else if (sectionId === 'referral') {
                loadReferralData();
            } else if (sectionId === 'admin') {
                loadAdminData();
            }
        }

        // Подключение кошелька
        function connectWallet() {
            showLoading();
            
            // В реальном приложении здесь была бы интеграция с MetaMask, WalletConnect и т.д.
            setTimeout(() => {
                // Имитация успешного подключения
                userData = {
                    walletAddress: '0x' + Math.random().toString(16).substr(2, 40),
                    balanceUSDT: 1000 + Math.random() * 1000,
                    balanceBNB: 0.5 + Math.random() * 2,
                    referrals: Math.floor(Math.random() * 50),
                    referralIncome: Math.floor(Math.random() * 500)
                };
                
                // Сохраняем данные
                localStorage.setItem('bitnest_user', JSON.stringify(userData));
                
                // Обновляем UI
                updateUI();
                
                hideLoading();
                showNotification('Кошелек успешно подключен!', 'success');
            }, 1500);
        }

        // Отключение кошелька
        function disconnectWallet() {
            showLoading();
            
            setTimeout(() => {
                userData = null;
                localStorage.removeItem('bitnest_user');
                
                // Обновляем UI
				updateUI();
                
                hideLoading();
                showNotification('Кошелек отключен', 'info');
            }, 1000);
        }

        // Обновление интерфейса
        function updateUI() {
            if (userData) {
                // Обновляем балансы
                document.getElementById('userBalance').textContent = userData.balanceUSDT.toFixed(2) + ' USDT';
                document.getElementById('dashboardBalance').textContent = userData.balanceUSDT.toFixed(2);
                document.getElementById('dashboardBnb').textContent = userData.balanceBNB.toFixed(4);
                document.getElementById('walletUsdt').textContent = userData.balanceUSDT.toFixed(2);
                document.getElementById('walletBnb').textContent = userData.balanceBNB.toFixed(4);
                document.getElementById('walletAddress').textContent = userData.walletAddress;
                
                // Обновляем реферальную информацию
                document.getElementById('totalReferrals').textContent = userData.referrals;
                document.getElementById('referralIncome').textContent = userData.referralIncome.toFixed(2) + ' USDT';
                document.getElementById('referralLink').textContent = `https://bitnest.ad/ref_${userData.walletAddress.substr(0, 10)}`;
                
                // Аватар пользователя
                document.getElementById('userAvatar').textContent = userData.walletAddress.substr(2, 1).toUpperCase();
                
                // Активируем кнопки
                document.getElementById('participateBtn').disabled = false;
                
                // Рассчитываем активированные уровни
                const investmentTotal = userData.balanceUSDT > 1000 ? 1000 : userData.balanceUSDT;
                const activeLevels = Math.min(17, Math.floor(investmentTotal / 100));
                document.getElementById('activeLevels').textContent = `${activeLevels}/17`;
                
                // Обновляем инвестиции
                document.getElementById('myInvestments').textContent = investmentTotal.toFixed(2) + ' USDT';
                document.getElementById('activeInvestments').textContent = investmentTotal.toFixed(2) + ' USDT';
            } else {
                // Сбрасываем значения
                document.getElementById('userBalance').textContent = '0.00 USDT';
                document.getElementById('dashboardBalance').textContent = '0.00';
                document.getElementById('dashboardBnb').textContent = '0.0000';
                document.getElementById('walletUsdt').textContent = '0.00';
                document.getElementById('walletBnb').textContent = '0.0000';
                document.getElementById('walletAddress').textContent = 'Не настроен';
                document.getElementById('totalReferrals').textContent = '0';
                document.getElementById('referralIncome').textContent = '0 USDT';
                document.getElementById('activeLevels').textContent = '0/17';
                document.getElementById('myInvestments').textContent = '0.00 USDT';
                document.getElementById('activeInvestments').textContent = '0.00 USDT';
                
                // Деактивируем кнопки
                document.getElementById('participateBtn').disabled = true;
            }
        }

        // Обновление сводки инвестиции
        function updateInvestmentSummary() {
            if (selectedAmount > 0 && selectedDays > 0) {
                const profitRates = {
                    1: 0.004,
                    7: 0.04,
                    14: 0.095,
                    28: 0.24
                };
                
                const profitRate = profitRates[selectedDays] || 0;
                const expectedProfit = selectedAmount * profitRate;
                const totalReturn = selectedAmount + expectedProfit;
                
                document.getElementById('summaryAmount').textContent = selectedAmount;
                document.getElementById('summaryDays').textContent = selectedDays;
                document.getElementById('summaryProfit').textContent = expectedProfit.toFixed(2);
                document.getElementById('summaryTotal').textContent = totalReturn.toFixed(2);
                
                document.getElementById('investmentSummary').style.display = 'block';
                document.getElementById('investBtn').disabled = false;
            } else {
                document.getElementById('investmentSummary').style.display = 'none';
                document.getElementById('investBtn').disabled = true;
            }
        }

        // Загрузка данных розыгрыша
        function loadRaffleData() {
            // Имитация загрузки данных с сервера
            const raffleData = {
                round: Math.floor(Math.random() * 10) + 1,
                prize: (500 + Math.random() * 1500).toFixed(2),
                participants: Math.floor(Math.random() * 500),
                endTime: Date.now() + 86400000 // Через 24 часа
            };
            
            document.getElementById('raffleRound').textContent = `#${raffleData.round}`;
            document.getElementById('rafflePrize').textContent = `${raffleData.prize} USDT`;
            document.getElementById('raffleParticipants').textContent = raffleData.participants;
            
            // Обновляем таймер
            updateRaffleTimer(raffleData.endTime);
            
            // Проверяем, может ли пользователь участвовать
            if (userData && userData.balanceUSDT >= 10) {
                document.getElementById('raffleStatus').innerHTML = '<p style="color: var(--success)">✅ Вы можете участвовать в розыгрыше</p>';
                document.getElementById('participateBtn').disabled = false;
            } else if (userData) {
                document.getElementById('raffleStatus').innerHTML = '<p style="color: var(--warning)">⚠️ Для участия необходимо минимум 10 USDT на балансе</p>';
                document.getElementById('participateBtn').disabled = true;
            } else {
                document.getElementById('raffleStatus').innerHTML = '<p style="color: var(--danger)">❌ Для участия необходимо подключить кошелек</p>';
                document.getElementById('participateBtn').disabled = true;
            }
        }

        // Обновление таймера розыгрыша
        function updateRaffleTimer(endTime) {
            function update() {
                const now = Date.now();
                const diff = endTime - now;
                
                if (diff <= 0) {
                    document.getElementById('raffleTime').textContent = '00:00:00';
                    return;
                }
                
                const hours = Math.floor(diff / (1000 * 60 * 60));
                const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((diff % (1000 * 60)) / 1000);
                
                document.getElementById('raffleTime').textContent = 
                    `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            }
            
            update();
            setInterval(update, 1000);
        }

        // Участие в розыгрыше
        function participateInRaffle() {
            if (!userData) {
                showNotification('Сначала подключите кошелек', 'error');
                return;
            }
            
            if (userData.balanceUSDT < 10) {
                showNotification('Недостаточно средств. Минимум 10 USDT', 'error');
                return;
            }
            
            showLoading();
            
            // Имитация участия в розыгрыше
            setTimeout(() => {
                hideLoading();
                showNotification('Вы успешно зарегистрированы в розыгрыше!', 'success');
                
                // Обновляем данные
                userData.balanceUSDT -= 10;
                localStorage.setItem('bitnest_user', JSON.stringify(userData));
                updateUI();
                
                // Обновляем количество участников
                const participants = document.getElementById('raffleParticipants');
                participants.textContent = parseInt(participants.textContent) + 1;
            }, 2000);
        }

        // Проверка статуса розыгрыша
        function checkRaffleStatus() {
            showLoading();
            
            setTimeout(() => {
                hideLoading();
                
                if (Math.random() > 0.8) {
                    showNotification('Поздравляем! Вы выиграли в розыгрыше!', 'success');
                    
                    // Добавляем выигрыш
                    const prize = parseFloat(document.getElementById('rafflePrize').textContent);
                    userData.balanceUSDT += prize;
                    localStorage.setItem('bitnest_user', JSON.stringify(userData));
                    updateUI();
                    
                    // Сбрасываем розыгрыш
                    setTimeout(loadRaffleData, 2000);
                } else {
                    showNotification('В этот раз не повезло. Попробуйте еще раз!', 'info');
                }
            }, 1500);
        }

        // Обработка инвестиции
        function processInvestment() {
            if (!userData) {
                showNotification('Сначала подключите кошелек', 'error');
                return;
            }
            
            if (selectedAmount <= 0 || selectedDays <= 0) {
                showNotification('Выберите сумму и срок инвестирования', 'error');
                return;
            }
            
            if (userData.balanceUSDT < selectedAmount) {
                showNotification('Недостаточно средств на балансе', 'error');
                return;
            }
            
            showLoading();
            
            // Имитация процесса инвестирования
            setTimeout(() => {
                hideLoading();
                
                // Обновляем баланс
                userData.balanceUSDT -= selectedAmount;
                localStorage.setItem('bitnest_user', JSON.stringify(userData));
                updateUI();
                
                showNotification(`Инвестиция на ${selectedAmount} USDT успешно оформлена!`, 'success');
                
                // Показываем детали инвестиции
                const profitRates = {
                    1: 0.004,
                    7: 0.04,
                    14: 0.095,
                    28: 0.24
                };
                
                const profitRate = profitRates[selectedDays];
                const expectedProfit = selectedAmount * profitRate;
                const returnDate = new Date(Date.now() + selectedDays * 86400000);
                
                alert(`✅ Инвестиция оформлена!\n\nСумма: ${selectedAmount} USDT\nСрок: ${selectedDays} дней\nОжидаемый доход: ${expectedProfit.toFixed(2)} USDT\nДата возврата: ${returnDate.toLocaleDateString()}`);
                
                // Сбрасываем выбор
                document.querySelectorAll('.investment-option').forEach(opt => {
                    opt.classList.remove('selected');
                });
                document.getElementById('customAmountSection').style.display = 'none';
                document.getElementById('investmentSummary').style.display = 'none';
                document.getElementById('investBtn').disabled = true;
                selectedAmount = 0;
                selectedDays = 0;
            }, 3000);
        }

        // Копирование реферальной ссылки
        function copyReferralLink() {
            const link = document.getElementById('referralLink').textContent;
            navigator.clipboard.writeText(link).then(() => {
                showNotification('Реферальная ссылка скопирована!', 'success');
            }).catch(err => {
                showNotification('Не удалось скопировать ссылку', 'error');
            });
        }

        // Показать детали реферальной программы
        function showReferralDetails() {
            alert('📊 Детальная статистика по реферальной программе\n\nЗдесь будет отображена подробная информация о ваших рефералах, их инвестициях и ваших доходах с каждого уровня.');
        }

        // Показать информацию об уровнях
        function showLevelInfo() {
            alert('🔓 Информация об уровнях партнерской программы\n\nУровень 1: 100$ - 20% дохода\nУровень 2: 200$ - 10% дохода\nУровень 3-7: 300-700$ - 5% дохода\nУровень 8-10: 800-1000$ - 3% дохода\nУровень 11-17: 1100-1700$ - 1% дохода\n\nДоход начисляется с инвестиций рефералов в пул ликвидности.');
        }

        // Обновление балансов
        function refreshBalances() {
            showLoading();
            
            // Имитация обновления балансов
            setTimeout(() => {
                if (userData) {
                    // Имитируем случайное изменение баланса
                    userData.balanceUSDT += (Math.random() * 10 - 5);
                    userData.balanceBNB += (Math.random() * 0.1 - 0.05);
                    
                    // Гарантируем, что баланс не отрицательный
                    userData.balanceUSDT = Math.max(0, userData.balanceUSDT);
                    userData.balanceBNB = Math.max(0, userData.balanceBNB);
                    
                    localStorage.setItem('bitnest_user', JSON.stringify(userData));
                    updateUI();
                    
                    showNotification('Балансы обновлены', 'success');
                }
                
                hideLoading();
            }, 1500);
        }

        // Смена языка
        function changeLanguage(lang) {
            showLoading();
            
            setTimeout(() => {
                hideLoading();
                showNotification(`Язык изменен на ${lang === 'ru' ? 'Русский' : 'English'}`, 'success');
                
                // Здесь должна быть реализация смены языка интерфейса
            }, 1000);
        }

        // Контакт с поддержкой
        function contactSupport() {
            window.open('https://t.me/BitnestSupport', '_blank');
        }

        // Открытие справки
        function openHelp() {
            alert('❓ Помощь и инструкции\n\nЗдесь будет раздел с Frequently Asked Questions и инструкциями по использованию платформы.');
        }

        // Проверка статуса администратора
        function checkAdminStatus() {
            // В реальном приложении здесь была бы проверка прав пользователя
            const adminWallet = '0xFCc442275A2620E40F17598F9987F320fB57526e';
            isAdmin = userData && userData.walletAddress.toLowerCase() === adminWallet.toLowerCase();
            
            if (isAdmin) {
                document.getElementById('adminTab').style.display = 'block';
            }
        }

        // Загрузка данных для админ-панели
        function loadAdminData() {
            if (!isAdmin) return;
            
            // Имитация данных для админ-панели
            document.getElementById('adminTotalUsers').textContent = Math.floor(Math.random() * 10000);
            document.getElementById('adminActiveRaffles').textContent = Math.floor(Math.random() * 5) + 1;
            document.getElementById('adminTotalPool').textContent = (1000000 + Math.random() * 9000000).toFixed(2) + ' USDT';
        }

        // Админ: установка приза
        function adminSetPrize() {
            if (!isAdmin) return;
            
            const newPrize = prompt('Введите новый призовой фонд (USDT):');
            if (newPrize && !isNaN(newPrize) && parseFloat(newPrize) > 0) {
                document.getElementById('rafflePrize').textContent = parseFloat(newPrize).toFixed(2) + ' USDT';
                showNotification('Призовой фонд обновлен', 'success');
            }
        }

        // Админ: установка времени
        function adminSetTimes() {
            if (!isAdmin) return;
            
            alert('Здесь будет функционал установки времени начала и окончания розыгрыша');
        }

        // Админ: приостановка/возобновление
        function adminTogglePause() {
            if (!isAdmin) return;
            
            alert('Здесь будет функционал приостановки и возобновления розыгрышей');
        }

        // Админ: выбор победителя
        function adminSelectWinner() {
            if (!isAdmin) return;
            
            alert('Здесь будет функционал выбора победителя розыгрыша');
        }

        // Показать уведомление
        function showNotification(message, type = 'info') {
            const notification = document.getElementById('notification');
            const messageElement = document.getElementById('notificationMessage');
            
            messageElement.textContent = message;
            notification.className = 'notification ' + type;
            notification.classList.add('show');
            
            setTimeout(() => {
                notification.classList.remove('show');
            }, 3000);
        }

        // Показать загрузку
        function showLoading() {
            document.getElementById('loading').style.display = 'block';
        }

        // Скрыть загрузку
        function hideLoading() {
            document.getElementById('loading').style.display = 'none';
        }
    </script>
</body>
</html>